<Window x:Class="TotoGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TotoGUI"
        mc:Ignorable="d"
        Title="Totó eredmény ellenőrző" Height="434" Width="578">
    <Grid>
        <TextBox x:Name="eredmeny" HorizontalAlignment="Left" Margin="147,151,0,0" TextWrapping="Wrap" Text="12X12X12X12X12" VerticalAlignment="Top" Width="159" TextChanged="eredmeny_TextChanged"/>
        <CheckBox IsEnabled="False" x:Name="karakterdb" Content="Nem megfelelő a karakterek száma (14)" HorizontalAlignment="Left" Margin="116,256,0,0" VerticalAlignment="Top" Width="303"/>
        <CheckBox IsEnabled="False" x:Name="karakterek" Content="Helytelen karakter az eredményben ()" HorizontalAlignment="Left" Margin="116,288,0,0" VerticalAlignment="Top" Width="287"/>
        <Button Content="Eredmények mentése" x:Name="mentes" HorizontalAlignment="Left" Margin="100,351,0,0" VerticalAlignment="Top" Width="155"/>
        <Label Content="Kérem a forduló eredményeit [1,2,X]:" HorizontalAlignment="Left" Margin="72,91,0,0" VerticalAlignment="Top" Width="269"/>

    </Grid>
</Window>
