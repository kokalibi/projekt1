<Window x:Class="matrixGUI2._1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:matrixGUI2._1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
        <StackPanel  HorizontalAlignment="Center" Orientation="Horizontal" DockPanel.Dock="Top"> 
            <TextBlock Text="Dátum" Margin="10"/>
            <ComboBox x:Name="datum" Width="120" Margin="10" SelectionChanged="datum_SelectionChanged"/>
        </StackPanel>
        <Button x:Name="mentes" Content="mentés" Width="150" Margin="10" DockPanel.Dock="Bottom" Click="mentes_Click"/>
        <UniformGrid x:Name="racs"/>
    </DockPanel>
</Window>
