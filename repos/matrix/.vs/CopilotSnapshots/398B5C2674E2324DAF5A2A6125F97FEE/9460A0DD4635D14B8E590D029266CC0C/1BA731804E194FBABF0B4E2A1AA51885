    public partial class MainWindow : Window
    {
        List<Class1> matrixLista = new List<Class1>();
        public MainWindow()
        {
            InitializeComponent();
            
            string[] fajlSorok = File.ReadAllLines("adatok.txt");
            List<string> sorok = new List<string>(fajlSorok);
            matrixLista.Add(new Class1(sorok));
            for (int i = 0; i < matrixLista[0].sor; i++)
            {
                for (int j = 0; j < matrixLista[0].oszlop; j++)
                {
                    grid.Children.Add(new TextBlock
                    {
                        Text = matrixLista[0].data[i, j].ToString(),
                        Margin = new Thickness(5),
                        HorizontalAlignment = HorizontalAlignment.Center,
                        VerticalAlignment = VerticalAlignment.Center
                    });
                }
            }
        }
    }
