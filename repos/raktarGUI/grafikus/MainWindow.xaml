<Window x:Class="grafikus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:grafikus"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <TextBlock Text="Polc: " TextWrapping="Wrap" VerticalAlignment="Center" Margin="5"/>
            <ComboBox x:Name="cmbPolcok" Width="200" Margin="5" SelectionChanged="cmbPolcok_SelectionChanged">
            </ComboBox>
            <Button x:Name="btnNev" Content="Név" Margin="5" Width="100" Click="btnNev_Click"/>
            <Button x:Name="btnSuly" Content="Súly" Margin="5" Width="100" Click="btnSuly_Click"/>
            <Button x:Name="btnMentes" Content="Mentés"  Margin="5" Width="100"/>
        </StackPanel>
        <UniformGrid x:Name="Racs" Rows="3" Columns="3">
        </UniformGrid>
    </DockPanel>
</Window>
            
        
